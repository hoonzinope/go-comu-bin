# Copy this file to `.env` and fill in real values before running Docker Compose.

# Docker image published to Docker Hub.
COMMU_BIN_IMAGE=docker.io/<your-user>/commu-bin:latest

# Host config file bind-mounted into the container.
COMMU_BIN_CONFIG_PATH=/Users/hoonzi/Documents/docker_v/go-commu-bin-data/config.yml

# Required JWT secret. Use a long random value.
DELIVERY_HTTP_AUTH_SECRET=replace-with-real-secret

# Optional overrides for local deployment.
# DELIVERY_HTTP_PORT=18577
# STORAGE_PROVIDER=local
# JOBS_ENABLED=true
# ADMIN_BOOTSTRAP_ENABLED=false
