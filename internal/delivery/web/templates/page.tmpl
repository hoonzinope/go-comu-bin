{{define "page"}}
<section class="page">
  {{if .Message}}<div class="banner">{{.Message}}</div>{{end}}
  {{if eq .Kind "feed"}}
    <div class="tab-strip">
      <a class="tab {{if or (eq .SortValue "") (eq .SortValue "hot")}}is-active{{end}}" href="/?sort=hot">Hot</a>
      <a class="tab {{if eq .SortValue "latest"}}is-active{{end}}" href="/?sort=latest">Latest</a>
      <a class="tab {{if eq .SortValue "top"}}is-active{{end}}" href="/?sort=top">Top</a>
    </div>
    <div class="page-heading">
      <h1>Feed</h1>
      <p>Latest discussion across visible boards.</p>
    </div>
    {{if and .Feed (gt (len .Feed.Posts) 0)}}
      <div class="stack">
        {{range .Feed.Posts}}
        <article class="panel feed-item">
          <div class="vote-rail">
            {{if $.Shell.IsAuthenticated}}
            <form action="/posts/{{.UUID}}/reactions" method="post" style="display:contents">
              <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
              <input type="hidden" name="reaction_type" value="like">
              <button type="submit">▲</button>
            </form>
            <strong>·</strong>
            <form action="/posts/{{.UUID}}/reactions" method="post" style="display:contents">
              <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
              <input type="hidden" name="reaction_type" value="dislike">
              <button type="submit">▼</button>
            </form>
            {{else}}
            <a href="/login">▲</a>
            <strong>·</strong>
            <a href="/login">▼</a>
            {{end}}
          </div>
          <div class="item-body">
            <div class="meta-row">
              <span class="chip">{{boardName $.Shell.BoardMap .BoardUUID}}</span>
              <span>@{{shortUUID .AuthorUUID}}</span>
              <span>{{formatTime .UpdatedAt}}</span>
            </div>
            <h2><a href="/posts/{{.UUID}}">{{.Title}}</a></h2>
            <p>{{truncate .Content 220}}</p>
          </div>
        </article>
        {{end}}
      </div>
    {{else}}
      <div class="panel empty">
        <p>No posts yet.</p>
        {{if and $.Shell.IsAuthenticated $.Shell.ComposeURL}}
        <a class="button button-primary empty-cta" href="{{$.Shell.ComposeURL}}">+ Write the first post</a>
        {{end}}
      </div>
    {{end}}
  {{else if eq .Kind "board"}}
    <div class="page-heading">
      <h1>{{boardName .Shell.BoardMap .BoardUUID}}</h1>
      <p>Board feed.</p>
    </div>
    {{template "page" (dict "Shell" .Shell "Kind" "feed" "Feed" .Feed "SortValue" .SortValue "BoardUUID" .BoardUUID)}}
  {{else if eq .Kind "tag"}}
    <div class="page-heading">
      <h1>#{{.TagName}}</h1>
      <p>Tag feed.</p>
    </div>
    {{template "page" (dict "Shell" .Shell "Kind" "feed" "Feed" .Feed "SortValue" .SortValue)}}
  {{else if eq .Kind "search"}}
    <div class="page-heading">
      <h1>Search</h1>
      <p>Query: {{if .Query}}"{{.Query}}"{{else}}enter a search term{{end}}</p>
    </div>
    {{if .Query}}
    <div class="tab-strip">
      <a class="tab {{if or (eq .SortValue "") (eq .SortValue "hot")}}is-active{{end}}" href="/search?q={{queryEscape .Query}}&sort=hot">Hot</a>
      <a class="tab {{if eq .SortValue "latest"}}is-active{{end}}" href="/search?q={{queryEscape .Query}}&sort=latest">Latest</a>
      <a class="tab {{if eq .SortValue "top"}}is-active{{end}}" href="/search?q={{queryEscape .Query}}&sort=top">Top</a>
    </div>
    {{end}}
    {{if .Feed}}
      {{if gt (len .Feed.Posts) 0}}
        <div class="stack">
          {{range .Feed.Posts}}
          <article class="panel feed-item">
            <div class="vote-rail">
              <button>▲</button>
              <strong>·</strong>
              <button>▼</button>
            </div>
            <div class="item-body">
              <div class="meta-row">
                <span class="chip">{{boardName $.Shell.BoardMap .BoardUUID}}</span>
                <span>@{{shortUUID .AuthorUUID}}</span>
                <span>{{formatTime .UpdatedAt}}</span>
              </div>
              <h2><a href="/posts/{{.UUID}}">{{.Title}}</a></h2>
              <p>{{truncate .Content 220}}</p>
            </div>
          </article>
          {{end}}
        </div>
      {{else}}
        <div class="panel empty">
          <p>No results found.</p>
          <a class="button empty-cta" href="/">Browse all posts</a>
        </div>
      {{end}}
    {{else}}
      <div class="panel empty">Search results appear here.</div>
    {{end}}
  {{else if eq .Kind "post"}}
    <div class="post-layout page-main">
      <article class="panel post-main">
        <div class="page-heading">
          <h1>{{.PostDetail.Post.Title}}</h1>
          <p>{{shortUUID .PostDetail.Post.UUID}} · {{formatTime .PostDetail.Post.UpdatedAt}}</p>
        </div>
        <div class="meta-row">
          <span class="chip">{{boardName $.Shell.BoardMap .PostDetail.Post.BoardUUID}}</span>
          <span>@{{shortUUID .PostDetail.Post.AuthorUUID}}</span>
          <span>{{len .PostDetail.Comments}} comments</span>
          <span>{{len .PostDetail.Attachments}} attachments</span>
        </div>
        {{if .PostDetail.Tags}}
        <div class="chip-row">
          {{range .PostDetail.Tags}}<a class="chip" href="/tags/{{.Name}}">{{.Name}}</a>{{end}}
        </div>
        {{end}}
        <pre class="markdown">{{.PostDetail.Post.Content}}</pre>
        {{if .PostDetail.Attachments}}
        <section id="attachments">
          <div class="section-title">Attachments</div>
          <div class="stack">
            {{range .PostDetail.Attachments}}
            <div class="panel attachment-row">
              <div>
                <div class="table-title">{{.FileName}}</div>
                <div class="table-sub">{{.ContentType}} · {{.SizeBytes}} bytes</div>
              </div>
              <span class="chip">{{shortUUID .UUID}}</span>
            </div>
            {{end}}
          </div>
        </section>
        {{end}}
        <section id="comments">
          <div class="section-title">Comments</div>
          {{if .PostDetail.Comments}}
            <div class="stack">
              {{range .PostDetail.Comments}}
              <div class="panel comment" x-data="{editing:false}">
                <div class="meta-row"><span>@{{shortUUID .Comment.AuthorUUID}}</span><span>{{formatTime .Comment.CreatedAt}}</span>
                  {{if and $.Shell.CurrentUser (eq $.Shell.CurrentUser.UUID .Comment.AuthorUUID)}}
                  <span class="button-row" style="margin-left:auto">
                    <button class="button" type="button" @click="editing=!editing">Edit</button>
                    <form action="/comments/{{.Comment.UUID}}/delete" method="post" style="display:contents">
                      <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
                      <input type="hidden" name="post_uuid" value="{{$.PostUUID}}">
                      <button class="button button-danger" type="submit" onclick="return confirm('Delete comment?')">Delete</button>
                    </form>
                  </span>
                  {{end}}
                </div>
                <p x-show="!editing">{{.Comment.Content}}</p>
                <form x-show="editing" action="/comments/{{.Comment.UUID}}" method="post">
                  <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
                  <input type="hidden" name="post_uuid" value="{{$.PostUUID}}">
                  <textarea name="content" rows="3">{{.Comment.Content}}</textarea>
                  <div class="button-row">
                    <button class="button button-primary" type="submit">Save</button>
                    <button class="button" type="button" @click="editing=false">Cancel</button>
                  </div>
                </form>
              </div>
              {{end}}
            </div>
          {{else}}
            <div class="empty">No comments yet.</div>
          {{end}}
        </section>
      </article>
      <aside class="panel post-sidebar">
        <div class="section-title">At a glance</div>
        <div class="meta-list">
          <div class="meta-item">
            <span>Board</span>
            <strong>{{boardName $.Shell.BoardMap .PostDetail.Post.BoardUUID}}</strong>
            <small>{{.PostDetail.Post.BoardUUID}}</small>
          </div>
          <div class="meta-item">
            <span>Author</span>
            <strong>@{{shortUUID .PostDetail.Post.AuthorUUID}}</strong>
            <small>{{.PostDetail.Post.AuthorUUID}}</small>
          </div>
          <div class="meta-item">
            <span>Created</span>
            <strong>{{formatTime .PostDetail.Post.CreatedAt}}</strong>
            <small>{{formatTime .PostDetail.Post.UpdatedAt}}</small>
          </div>
          <div class="meta-item">
            <span>Comments</span>
            <strong>{{len .PostDetail.Comments}}</strong>
            <small>{{if .PostDetail.CommentsHasMore}}More available{{else}}Loaded in full{{end}}</small>
          </div>
          <div class="meta-item">
            <span>Reactions</span>
            <strong>{{len .PostDetail.Reactions}}</strong>
            <small>Post-level feedback</small>
          </div>
        </div>
        <div class="section-title">Quick jumps</div>
        <div class="button-row">
          <a class="button" href="#comments">Comments</a>
          {{if .PostDetail.Attachments}}<a class="button" href="#attachments">Attachments</a>{{end}}
          <a class="button" href="/">Back to feed</a>
        </div>
        {{if .Shell.IsAuthenticated}}
        <div class="section-title">Reactions</div>
        <div class="button-row">
          <form action="/posts/{{.PostUUID}}/reactions" method="post">
            <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
            <input type="hidden" name="reaction_type" value="like">
            <button class="button {{if reactionActive .PostDetail.MyReactionType "like"}}button-primary is-active{{end}}" type="submit">▲ Upvote</button>
          </form>
          <form action="/posts/{{.PostUUID}}/reactions" method="post">
            <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
            <input type="hidden" name="reaction_type" value="dislike">
            <button class="button {{if reactionActive .PostDetail.MyReactionType "dislike"}}button-primary is-active{{end}}" type="submit">▼ Downvote</button>
          </form>
          <form action="/posts/{{.PostUUID}}/reactions" method="post">
            <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
            <input type="hidden" name="_method" value="delete">
            <button class="button button-ghost" type="submit">Remove</button>
          </form>
        </div>
        {{if and .Shell.CurrentUser (eq .Shell.CurrentUser.UUID .PostDetail.Post.AuthorUUID)}}
        <div class="section-title">Manage</div>
        <div class="button-row">
          <a class="button" href="/posts/{{.PostUUID}}/edit">Edit</a>
          <form action="/posts/{{.PostUUID}}/delete" method="post" style="display:contents">
            <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
            <button class="button button-danger" type="submit" onclick="return confirm('Delete this post?')">Delete</button>
          </form>
        </div>
        {{end}}
        <div class="section-title">Report</div>
        <form action="/reports" method="post" x-data="{open:false}">
          <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
          <input type="hidden" name="target_type" value="post">
          <input type="hidden" name="target_uuid" value="{{.PostUUID}}">
          <input type="hidden" name="redirect" value="/posts/{{.PostUUID}}">
          <select name="reason_code">
            <option value="spam">Spam</option>
            <option value="abuse">Abuse</option>
            <option value="sexual">Sexual</option>
            <option value="violence">Violence</option>
            <option value="illegal">Illegal</option>
            <option value="other">Other</option>
          </select>
          <textarea name="reason_detail" rows="2" placeholder="Optional detail"></textarea>
          <button class="button" type="submit">Report</button>
        </form>
        {{end}}
      </aside>
    </div>
    {{if .Shell.IsAuthenticated}}
    <form class="panel form comment-form" action="/posts/{{.PostUUID}}/comments" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <label>Write a comment</label>
      <textarea name="content" rows="5" placeholder="Share your reply"></textarea>
      <button class="button button-primary" type="submit">Comment</button>
    </form>
    {{else}}
    <div class="panel form comment-form">
      <label>Write a comment</label>
      <textarea name="content" rows="5" placeholder="Share your reply" disabled></textarea>
      <a class="button button-primary" href="/login?redirect={{queryEscape (printf "/posts/%s" .PostUUID)}}">Login to comment</a>
    </div>
    {{end}}
  {{else if eq .Kind "compose"}}
    <div class="page-heading">
      <h1>{{if eq .EditMode "edit"}}Edit draft{{else if eq .EditMode "draft"}}New draft{{else}}New post{{end}}</h1>
      <p>{{.BoardUUID}}</p>
    </div>
    <div class="compose-layout page-main">
      <aside class="panel compose-sidebar">
        <div class="section-title">Workspace</div>
        <div class="meta-list">
          <div class="meta-item">
            <span>Board</span>
            <strong>{{boardName $.Shell.BoardMap .BoardUUID}}</strong>
            <small>{{.BoardUUID}}</small>
          </div>
          <div class="meta-item">
            <span>Mode</span>
            <strong>{{if eq .EditMode "edit"}}Draft edit{{else if eq .EditMode "draft"}}Save draft{{else}}Publish now{{end}}</strong>
            <small>{{if eq .EditMode "edit"}}Update an existing draft{{else if eq .EditMode "draft"}}Keep working before publish{{else}}Create a live post{{end}}</small>
          </div>
          <div class="meta-item">
            <span>Access</span>
            <strong>Public</strong>
            <small>Visible on the board feed.</small>
          </div>
          <div class="meta-item">
            <span>Guidance</span>
            <strong>Keep it structured</strong>
            <small>Use short paragraphs, tags, and markdown headings.</small>
          </div>
        </div>
        <div class="section-title">Checklist</div>
        <div class="stack">
          <div class="chip">Title set</div>
          <div class="chip">Tags reviewed</div>
          <div class="chip">Content ready</div>
        </div>
      </aside>
      <form class="panel form compose-main" action="{{if eq .EditMode "edit"}}/posts/{{.PostUUID}}{{else if eq .EditMode "draft"}}/boards/{{.BoardUUID}}/posts/drafts{{else}}/boards/{{.BoardUUID}}/posts{{end}}" method="post">
        <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
        <div class="section-title">Content</div>
        <label>Title</label>
        <input type="text" name="title" value="{{.TitleInput}}" placeholder="Post title">
        <label>Tags</label>
        <input type="text" name="tags" value="{{.TagsInput}}" placeholder="go, ui, roadmap">
        <label>Content</label>
        <textarea name="content" rows="18" placeholder="Write markdown">{{.ContentInput}}</textarea>
        <div class="button-row">
          {{if eq .EditMode "edit"}}
            <button class="button button-primary" type="submit">Update draft</button>
            <button class="button" type="submit" formaction="/posts/{{.PostUUID}}/publish">Publish</button>
          {{else if eq .EditMode "draft"}}
            <button class="button button-primary" type="submit">Save draft</button>
          {{else}}
            <button class="button button-primary" type="submit">Publish</button>
          {{end}}
        </div>
      </form>
    </div>
  {{else if eq .Kind "login"}}
    <div class="auth-grid">
      <form class="panel form" action="/login{{if .Redirect}}?redirect={{queryEscape .Redirect}}{{end}}" method="post">
        <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
        <input type="hidden" name="redirect" value="{{.Redirect}}">
        <h1>Login</h1>
        <label>Username</label>
        <input type="text" name="username" value="{{.LoginUsername}}">
        <label>Password</label>
        <input type="password" name="password">
        <button class="button button-primary" type="submit">Login</button>
        <a href="/reset-password">Forgot password?</a>
      </form>
      <form class="panel form" action="/signup{{if .Redirect}}?redirect={{queryEscape .Redirect}}{{end}}" method="post">
        <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
        <input type="hidden" name="redirect" value="{{.Redirect}}">
        <h2>Guest to account</h2>
        <label>Username</label>
        <input type="text" name="username">
        <label>Email</label>
        <input type="email" name="email">
        <label>Password</label>
        <input type="password" name="password">
        <button class="button" type="submit">Sign up</button>
      </form>
    </div>
  {{else if eq .Kind "signup"}}
    <form class="panel form" action="/signup{{if .Redirect}}?redirect={{queryEscape .Redirect}}{{end}}" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <input type="hidden" name="redirect" value="{{.Redirect}}">
      <h1>Sign up</h1>
      <label>Username</label>
      <input type="text" name="username">
      <label>Email</label>
      <input type="email" name="email">
      <label>Password</label>
      <input type="password" name="password">
      <button class="button button-primary" type="submit">Create account</button>
    </form>
  {{else if eq .Kind "verify-email"}}
    <form class="panel form" action="/verify-email" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <h1>Verify email</h1>
      <label>Token</label>
      <input type="text" name="token" value="{{.VerifyToken}}">
      <button class="button button-primary" type="submit">Confirm</button>
    </form>
  {{else if eq .Kind "reset-password"}}
    {{if .ResetToken}}
    <form class="panel form" action="/reset-password" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <h1>Reset password</h1>
      <label>Token</label>
      <input type="text" name="token" value="{{.ResetToken}}">
      <label>New password</label>
      <input type="password" name="new_password">
      <button class="button button-primary" type="submit">Reset</button>
    </form>
    {{else}}
    <form class="panel form" action="/reset-password" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <h1>Forgot password</h1>
      <label>Email</label>
      <input type="email" name="email" required>
      <button class="button button-primary" type="submit">Send reset link</button>
    </form>
    {{end}}
  {{else if eq .Kind "me"}}
    <div class="page-heading">
      <h1>My page</h1>
      <p>{{.Shell.CurrentUser.Name}} · {{.Shell.CurrentUser.Email}}</p>
    </div>
    {{if .Shell.CurrentUser.Guest}}
    <div class="panel form">
      <h2>Guest account</h2>
      <p>Upgrade to a full account to unlock all features.</p>
      <a class="button button-primary" href="/me/upgrade">Upgrade account</a>
    </div>
    {{end}}
    {{if and (not .Shell.CurrentUser.Guest) (not .Shell.CurrentUser.EmailVerifiedAt)}}
    <div class="panel form">
      <h2>Email not verified</h2>
      <form action="/me/verify-email" method="post" style="display:contents">
        <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
        <button class="button button-primary" type="submit">Send verification email</button>
      </form>
    </div>
    {{end}}
    <div class="grid-2">
      {{if not .Shell.CurrentUser.Guest}}
      <form class="panel form" action="/me/delete" method="post">
        <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
        <h2>Delete account</h2>
        <label>Password</label>
        <input type="password" name="password">
        <button class="button button-danger" type="submit">Delete</button>
      </form>
      {{end}}
      <section class="panel">
        <h2>Drafts</h2>
        {{if .Drafts}}
          {{range .Drafts.Posts}}
            <div class="list-row"><a href="/posts/{{.UUID}}/edit">{{.Title}}</a><span>{{formatTime .UpdatedAt}}</span></div>
          {{end}}
        {{else}}
          <div class="empty">
            <p>No drafts yet.</p>
            {{if $.Shell.ComposeURL}}
            <a class="button empty-cta" href="{{$.Shell.ComposeURL}}">+ Start a draft</a>
            {{end}}
          </div>
        {{end}}
      </section>
    </div>
  {{else if eq .Kind "notifications"}}
    <div class="page-heading">
      <h1>Notifications</h1>
      <p>Unread: {{.Shell.UnreadCount}}</p>
    </div>
    <form action="/notifications/read-all" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <button class="button" type="submit">Mark all read</button>
    </form>
    {{if .Notifications}}
      <div class="stack">
        {{range .Notifications.Notifications}}
        <div class="panel">
          <div class="meta-row"><span>{{.MessageKey}}</span><span>{{formatTime .CreatedAt}}</span>
            {{if not .ReadAt}}
            <form action="/notifications/{{.UUID}}/read" method="post" style="display:contents">
              <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
              <button class="button" type="submit" style="margin-left:auto">Mark read</button>
            </form>
            {{end}}
          </div>
          <p>{{.PostTitle}}</p>
        </div>
        {{end}}
      </div>
    {{end}}
  {{else if eq .Kind "admin-reports"}}
    <div class="page-heading"><h1>Reports</h1><p>Moderation queue.</p></div>
    {{if .Reports}}
      <div class="panel table-panel">
        <div class="table-head report-grid">
          <div>Report</div>
          <div>Target</div>
          <div>Decision</div>
          <div>Action</div>
        </div>
        <div class="table-body">
          {{range .Reports.Reports}}
          <form class="table-row report-grid" action="/admin/reports/{{.ID}}/resolve" method="post">
            <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
            <div data-label="Report">
              <div class="table-title">#{{.ID}} · {{.ReasonCode}}</div>
              <div class="table-sub">By @{{shortUUID .ReporterUUID}} · {{formatTime .CreatedAt}}</div>
              <div class="chip-row">
                <span class="chip {{if eq .Status "pending"}}chip-pending{{else if eq .Status "accepted"}}chip-active{{else if eq .Status "rejected"}}chip-dead{{end}}">{{.Status}}</span>
                {{if .ResolvedAt}}<span class="chip chip-active">resolved</span>{{end}}
              </div>
            </div>
            <div data-label="Target">
              <div class="table-title">{{.TargetType}}</div>
              <div class="table-sub">{{.TargetUUID}}</div>
              <div class="table-sub">{{if .ResolvedAt}}Resolved{{else}}Awaiting review{{end}}</div>
            </div>
            <div class="form" data-label="Decision">
              <label>Status</label>
              <input type="text" name="status" value="{{.Status}}" placeholder="accepted / rejected">
              <label>Note</label>
              <input type="text" name="resolution_note" value="{{.ResolutionNote}}" placeholder="Optional note">
            </div>
            <div class="button-row" data-label="Action">
              <button class="button button-primary" type="submit">Resolve</button>
            </div>
          </form>
          {{end}}
        </div>
      </div>
    {{end}}
  {{else if eq .Kind "admin-outbox"}}
    <div class="page-heading"><h1>Dead outbox</h1><p>Retry or discard failed messages.</p></div>
    {{if .Outbox}}
      <div class="panel table-panel">
        <div class="table-head outbox-grid">
          <div>Message</div>
          <div>Schedule</div>
          <div>Error</div>
          <div>Action</div>
        </div>
        <div class="table-body">
          {{range .Outbox.Messages}}
          <div class="table-row outbox-grid">
            <div data-label="Message">
              <div class="table-title">{{.EventName}}</div>
              <div class="table-sub">{{.ID}}</div>
              <div class="chip-row"><span class="chip chip-dead">dead</span><span class="chip chip-pending">Attempts x{{.AttemptCount}}</span></div>
            </div>
            <div data-label="Schedule">
              <div class="table-title">{{formatTime .OccurredAt}}</div>
              <div class="table-sub">Retry at {{formatTime .NextAttemptAt}}</div>
            </div>
            <div data-label="Error">
              <div class="table-title">Last error</div>
              <div class="table-sub">{{.LastError}}</div>
            </div>
            <div class="button-row" data-label="Action">
              <form action="/admin/outbox/dead/{{.ID}}/requeue" method="post">
                <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
                <button class="button" type="submit">Requeue</button>
              </form>
              <form action="/admin/outbox/dead/{{.ID}}/discard" method="post">
                <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
                <button class="button button-danger" type="submit">Discard</button>
              </form>
            </div>
          </div>
          {{end}}
        </div>
      </div>
    {{end}}
  {{else if eq .Kind "admin-boards"}}
    <div class="page-heading">
      <h1>Boards</h1>
      <p>Visibility management.</p>
    </div>
    <form class="panel form" action="/admin/boards" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <div class="section-title">Create new board</div>
      <label>Name</label>
      <input type="text" name="name" placeholder="Board name" required>
      <label>Description</label>
      <input type="text" name="description" placeholder="Short description">
      <button class="button button-primary" type="submit">Create board</button>
    </form>
    {{if .AdminBoards}}
      <div class="stats-grid">
        <div class="panel stat-card">
          <div class="stat-label">Visible</div>
          <div class="stat-value">{{.BoardVisibleCount}}</div>
        </div>
        <div class="panel stat-card">
          <div class="stat-label">Hidden</div>
          <div class="stat-value">{{.BoardHiddenCount}}</div>
        </div>
        <div class="panel stat-card">
          <div class="stat-label">Total</div>
          <div class="stat-value">{{len .AdminBoards.Boards}}</div>
        </div>
      </div>
      <div class="panel table-panel">
        <div class="table-head">
          <div>Board</div>
          <div>Status</div>
          <div>Action</div>
        </div>
        <div class="table-body">
          {{range .AdminBoards.Boards}}
          <div class="table-row">
            <div data-label="Board">
              <div class="table-title">{{.Name}}</div>
              <div class="table-sub">{{.UUID}}</div>
              <div class="table-sub">{{.Description}}</div>
            </div>
            <div data-label="Status"><span class="chip {{if .Hidden}}chip-hidden{{else}}chip-active{{end}}">{{if .Hidden}}Hidden{{else}}Visible{{end}}</span></div>
            <div class="button-row" data-label="Action">
              <a class="button" href="/admin/boards/{{.UUID}}/edit">Edit</a>
              <form action="/admin/boards/{{.UUID}}/visibility" method="post" style="display:contents">
                <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
                {{if .Hidden}}
                  <input type="hidden" name="hidden" value="false">
                  <button class="button" type="submit">Show</button>
                {{else}}
                  <input type="hidden" name="hidden" value="true">
                  <button class="button button-danger" type="submit">Hide</button>
                {{end}}
              </form>
              <form action="/admin/boards/{{.UUID}}/delete" method="post" style="display:contents">
                <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
                <button class="button button-danger" type="submit" onclick="return confirm('Delete this board?')">Delete</button>
              </form>
            </div>
          </div>
          {{end}}
        </div>
      </div>
    {{else}}
      <div class="panel empty">No boards available.</div>
    {{end}}
  {{else if eq .Kind "me-upgrade"}}
    <div class="page-heading">
      <h1>Upgrade account</h1>
      <p>Create a full account from your guest session.</p>
    </div>
    <form class="panel form" action="/me/upgrade" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <label>Username</label>
      <input type="text" name="username" required>
      <label>Email</label>
      <input type="email" name="email" required>
      <label>Password</label>
      <input type="password" name="password" required>
      <div class="button-row">
        <button class="button button-primary" type="submit">Create account</button>
        <a class="button" href="/me">Cancel</a>
      </div>
    </form>
  {{else if eq .Kind "admin-board-edit"}}
    <div class="page-heading">
      <h1>Edit Board</h1>
      {{if .AdminBoardTarget}}<p>{{.AdminBoardTarget.Name}}</p>{{end}}
    </div>
    <form class="panel form" action="/admin/boards/{{.BoardUUID}}" method="post">
      <input type="hidden" name="_csrf" value="{{.Shell.CSRFToken}}">
      <label>Name</label>
      <input type="text" name="name" value="{{if .AdminBoardTarget}}{{.AdminBoardTarget.Name}}{{end}}" required>
      <label>Description</label>
      <input type="text" name="description" value="{{if .AdminBoardTarget}}{{.AdminBoardTarget.Description}}{{end}}">
      <div class="button-row">
        <button class="button button-primary" type="submit">Save</button>
        <a class="button" href="/admin/boards">Cancel</a>
      </div>
    </form>
  {{else if eq .Kind "admin-snapshot"}}
    <div class="page-heading">
      <h1>Admin Snapshot</h1>
      <p>Board visibility and moderation queue.</p>
    </div>
    <div class="stats-grid">
      <div class="panel stat-card">
        <div class="stat-label">Reports</div>
        <div class="stat-value">{{if .Reports}}{{len .Reports.Reports}}{{else}}0{{end}}</div>
      </div>
      <div class="panel stat-card">
        <div class="stat-label">Dead outbox</div>
        <div class="stat-value">{{if .Outbox}}{{len .Outbox.Messages}}{{else}}0{{end}}</div>
      </div>
      <div class="panel stat-card">
        <div class="stat-label">Hidden boards</div>
        <div class="stat-value">{{.BoardHiddenCount}}</div>
      </div>
    </div>
    <div class="button-row">
      <a class="button" href="/admin/reports">Reports</a>
      <a class="button" href="/admin/outbox">Outbox</a>
      <a class="button" href="/admin/boards">Boards</a>
    </div>
    <div class="panel form" x-data="{userUUID:''}">
      <h2>User Suspension</h2>
      <label>User UUID</label>
      <input type="text" x-model="userUUID" placeholder="Enter user UUID">
      <a class="button button-primary" :href="'/admin/users/'+userUUID+'/suspension'">Manage</a>
    </div>
  {{else if eq .Kind "admin-suspension"}}
    <div class="page-heading"><h1>User suspension</h1><p>{{if .Suspension}}{{.Suspension.UserUUID}}{{end}}</p></div>
    {{if and .Suspension (eq .Suspension.Status "suspended")}}
    <div class="panel form">
      <p>This user is currently suspended. Reason: {{.Suspension.Reason}}</p>
      <form action="/admin/users/{{.Suspension.UserUUID}}/suspension" method="post">
        <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
        <input type="hidden" name="_method" value="unsuspend">
        <button class="button button-primary" type="submit">Unsuspend</button>
      </form>
    </div>
    {{else}}
    <form class="panel form" action="/admin/users/{{if .Suspension}}{{.Suspension.UserUUID}}{{end}}/suspension" method="post">
      <input type="hidden" name="_csrf" value="{{$.Shell.CSRFToken}}">
      <label>Reason</label>
      <input type="text" name="reason">
      <label>Duration</label>
      <input type="text" name="duration" placeholder="7d / 15d / 30d / unlimited">
      <button class="button button-primary" type="submit">Suspend</button>
    </form>
    {{end}}
  {{else if eq .Kind "error"}}
    <div class="panel error-panel">
      <h1>{{.Shell.Title}}</h1>
      <p>{{.ErrorMessage}}</p>
    </div>
  {{else}}
    <div class="panel empty">Nothing to render.</div>
  {{end}}
</section>
{{end}}
